{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A customer appointment booking.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The customer's full name."
        },
        "phone": {
          "type": "string",
          "description": "The customer's phone number."
        },
        "service": {
          "type": "string",
          "description": "The type of service requested."
        },
        "carType": {
          "type": "string",
          "description": "The type of car (optional)."
        },
        "date": {
          "type": "string",
          "description": "The date of the appointment."
        },
        "time": {
          "type": "string",
          "description": "The time of the appointment."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "cancelled"],
          "description": "The current status of the booking."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the booking was created."
        }
      },
      "required": ["name", "phone", "service", "date", "time", "status", "createdAt"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all appointment bookings."
    }
  }
}
